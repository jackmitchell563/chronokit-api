# ChronoKit API — environment variables
# ─────────────────────────────────────────────────────────────────────────────
# This file documents every variable. Copy it to `.dev.vars` for local `wrangler dev`
# (that file is gitignored). In PRODUCTION, set secrets with `wrangler secret put …`
# and non-secret vars in wrangler.toml [vars] or the Cloudflare dashboard.
#
# The Worker is STATELESS — there is no database, queue, or storage binding, so there
# are no connection strings or third-party API keys to manage.
# ─────────────────────────────────────────────────────────────────────────────

# ── RapidAPI proxy-secret verification ──────────────────────────────────────
# RapidAPI injects this exact value as the `X-RapidAPI-Proxy-Secret` header on every
# request it forwards to your origin. Verifying it stops people from calling your
# Worker URL directly and bypassing RapidAPI's metering/billing.
#
# WHERE TO GET IT: RapidAPI Provider Dashboard → your API → "Security" tab →
#   "Specify Headers" / "Proxy Secret". RapidAPI generates the value; copy it here.
#   (You can also paste any random string and configure RapidAPI to send it.)
# Set in production with:  wrangler secret put RAPIDAPI_PROXY_SECRET
RAPIDAPI_PROXY_SECRET=replace-with-the-value-from-rapidapi

# Turn enforcement ON in production. When "true", requests without a valid proxy
# secret get a 401. Keep "false" locally so `wrangler dev` and `pnpm seed` work
# without a secret. (Defined in wrangler.toml [vars]; override per-environment.)
ENFORCE_RAPIDAPI_PROXY=false

# ── Result cap (non-secret) ─────────────────────────────────────────────────
# Hard upper bound on results returned per call, regardless of the requested count.
# Mirrors your RapidAPI Free-tier cap (50). Raise for higher tiers if you split
# deployments, but the code also enforces an absolute ceiling of 1000.
MAX_RESULTS=50
