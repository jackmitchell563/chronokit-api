{
  "name": "chronokit-api",
  "version": "1.0.0",
  "private": true,
  "description": "ChronoKit API — DST-correct recurrence (RRULE), cron, and business-day computation as stateless HTTP. Hono on Cloudflare Workers.",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "wrangler dev",
    "build": "wrangler deploy --dry-run --outdir dist",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "e2e": "pnpm run test:e2e",
    "seed": "tsx scripts/seed.ts",
    "openapi:dump": "tsx scripts/dump-openapi.ts"
  },
  "dependencies": {
    "@hono/swagger-ui": "0.6.1",
    "@hono/zod-openapi": "1.4.0",
    "cron-parser": "5.5.0",
    "cronstrue": "3.14.0",
    "hono": "4.12.23",
    "luxon": "3.7.2",
    "rrule": "2.8.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@cloudflare/workers-types": "4.20260531.1",
    "@types/luxon": "3.7.1",
    "@types/node": "22.15.21",
    "tsx": "4.20.6",
    "typescript": "5.9.3",
    "vitest": "3.2.4",
    "wrangler": "4.95.0"
  },
  "packageManager": "pnpm@8.15.9"
}
